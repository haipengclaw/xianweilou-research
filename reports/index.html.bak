<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="referrer" content="no-referrer">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>仙味楼 · 菜品研发数据库</title>
<style>
* { margin: 0; padding: 0; box-sizing: border-box; }
body { font-family: -apple-system, 'PingFang SC', 'Microsoft YaHei', sans-serif; background: #f5f5f5; color: #333; }
.header { background: linear-gradient(135deg,#c0392b,#e74c3c); color: #fff; padding: 50px 20px 40px; text-align: center; }
.header h1 { font-size: 30px; margin-bottom: 6px; }
.header .sub { font-size: 14px; opacity: .85; margin-top: 6px; }
.container { max-width: 1100px; margin: 0 auto; padding: 30px 20px; }

/* Category Cards */
.cat-grid { display: grid; grid-template-columns: repeat(2,1fr); gap: 16px; margin-bottom: 30px; }
.cat-card { background: #fff; border-radius: 16px; padding: 24px; box-shadow: 0 2px 12px rgba(0,0,0,.08); cursor: pointer; transition: transform .2s,box-shadow .2s; text-decoration: none; color: #333; display: block; position: relative; overflow: hidden; }
.cat-card:hover { transform: translateY(-3px); box-shadow: 0 6px 20px rgba(0,0,0,.12); }
.cat-card .icon { font-size: 36px; margin-bottom: 10px; }
.cat-card h3 { font-size: 18px; font-weight: 700; margin-bottom: 4px; }
.cat-card .count { font-size: 13px; color: #999; }
.cat-card .tag { display: inline-block; background: #fef3f2; color: #c0392b; padding: 2px 10px; border-radius: 10px; font-size: 12px; margin-top: 8px; }
.cat-card .bar { position: absolute; top: 0; left: 0; right: 0; height: 4px; }
.cat-card:nth-child(1) .bar { background: linear-gradient(90deg,#2c3e50,#34495e); }
.cat-card:nth-child(2) .bar { background: linear-gradient(90deg,#e74c3c,#f39c12); }
.cat-card:nth-child(3) .bar { background: linear-gradient(90deg,#8e44ad,#3498db); }
.cat-card:nth-child(4) .bar { background: linear-gradient(90deg,#d35400,#e67e22); }

/* Research List Summary */
.list-summary { background: #fff; border-radius: 16px; padding: 24px; box-shadow: 0 2px 12px rgba(0,0,0,.08); margin-bottom: 24px; }
.list-summary h3 { font-size: 16px; margin-bottom: 10px; display: flex; align-items: center; gap: 8px; }
.list-summary .empty { color: #bbb; font-size: 14px; text-align: center; padding: 20px; }
.list-summary .item { display: flex; align-items: center; gap: 10px; padding: 8px 10px; border-radius: 8px; background: #fafafa; margin-bottom: 6px; font-size: 13px; }
.list-summary .item .dish { font-weight: 600; }
.list-summary .item .shop { color: #888; }
.list-summary .item .remove { cursor: pointer; color: #e74c3c; font-size: 16px; margin-left: auto; flex-shrink: 0; }
.list-summary .actions { display: flex; gap: 10px; margin-top: 12px; flex-wrap: wrap; }
.btn { padding: 8px 20px; border-radius: 8px; border: none; font-size: 13px; cursor: pointer; font-weight: 600; }
.btn-primary { background: #c0392b; color: #fff; }
.btn-primary:hover { background: #a93226; }
.btn-secondary { background: #eee; color: #666; }
.btn-secondary:hover { background: #ddd; }
.list-summary .total { font-weight: 700; color: #c0392b; }

/* Footer */
.footer { text-align: center; padding: 30px; color: #999; font-size: 12px; }

/* Responsive */
@media (max-width: 768px) { .cat-grid { grid-template-columns: 1fr; } }

.page-link { display: inline-block; margin-top: 10px; padding: 6px 16px; background: #f5f5f5; border-radius: 8px; color: #666; text-decoration: none; font-size: 12px; }
.page-link:hover { background: #eee; }
</style>
</head>
<body>

<div class="header">
<h1>🍜 仙味楼 · 菜品研发数据库</h1>
<div class="sub">上海本帮菜餐厅研究 · 2026年6月</div>
</div>

<div class="container">

<div class="cat-grid">
<a class="cat-card" href="上海本帮菜_黑珍珠_20260622.html">
<div class="bar"></div>
<div class="icon">🖤</div>
<h3>黑珍珠</h3>
<div class="count">收录 15 家餐厅</div>
<span class="tag">高端精致</span>
</a>

<a class="cat-card" href="上海本帮菜_必吃榜_20260622.html">
<div class="bar"></div>
<div class="icon">🏆</div>
<h3>必吃榜</h3>
<div class="count">收录 21 家餐厅</div>
<span class="tag">人气口碑</span>
</a>

<a class="cat-card" href="上海本帮菜_排队_20260622.html">
<div class="bar"></div>
<div class="icon">🚶</div>
<h3>排队王</h3>
<div class="count">收录 60 家餐厅</div>
<span class="tag">火爆排队</span>
</a>

<a class="cat-card" href="上海本帮菜_老字号_20260622.html">
<div class="bar"></div>
<div class="icon">🏛️</div>
<h3>老字号</h3>
<div class="count">收录 60 家餐厅</div>
<span class="tag">经典传承</span>
</a>
</div>

<!-- Research List Summary -->
<div class="list-summary" id="listSummary">
<h3>📋 菜品研究方向清单 <span class="total" id="listCount">0</span></h3>
<div id="listItems" class="empty">还没有选中任何菜品，进入上方分类报告，点击菜品卡片上的 ☆ 即可收藏</div>
<div class="actions" id="listActions" style="display:none">
<button class="btn btn-primary" onclick="exportList()">📤 导出研究清单</button>
<button class="btn btn-secondary" onclick="clearList()">🗑️ 清空清单</button>
</div>
</div>

<div class="footer">
<p>仙味楼 R&D 助手 · 数据来源：大众点评 · 不定期更新</p>
<p style="margin-top:4px">点击菜品卡片上的 ☆ 收藏到研究清单 · 勾选的菜会出现在下方清单中</p>
</div>

</div>

<script>
// Load research list from localStorage
function loadList() {
  try {
    return JSON.parse(localStorage.getItem('researchList') || '[]');
  } catch(e) { return []; }
}

function saveList(list) {
  localStorage.setItem('researchList', JSON.stringify(list));
}

function renderList() {
  const list = loadList();
  const container = document.getElementById('listItems');
  const count = document.getElementById('listCount');
  const actions = document.getElementById('listActions');

  count.textContent = list.length;

  if (list.length === 0) {
    container.innerHTML = '<div class="empty">还没有选中任何菜品，进入上方分类报告，点击菜品卡片上的 ☆ 即可收藏</div>';
    actions.style.display = 'none';
    return;
  }

  actions.style.display = 'flex';
  container.innerHTML = list.map((item, i) =>
    `<div class="item">
      <span class="dish">${item.dish}</span>
      <span class="shop">— ${item.shop}</span>
      <span class="remove" onclick="removeItem(${i})">✕</span>
    </div>`
  ).join('');
}

function removeItem(index) {
  const list = loadList();
  list.splice(index, 1);
  saveList(list);
  renderList();
}

function clearList() {
  if (confirm('确定清空研究清单吗？')) {
    saveList([]);
    renderList();
  }
}

function exportList() {
  const list = loadList();
  if (list.length === 0) { alert('清单为空'); return; }

  // Group by shop
  const grouped = {};
  list.forEach(item => {
    if (!grouped[item.shop]) grouped[item.shop] = [];
    grouped[item.shop].push(item.dish);
  });

  let text = '=== 仙味楼 菜品研究方向清单 ===\n\n';
  text += `生成日期：${new Date().toLocaleDateString()}\n`;
  text += `共 ${list.length} 道菜品\n\n`;

  let i = 1;
  Object.entries(grouped).forEach(([shop, dishes]) => {
    text += `【${shop}】\n`;
    dishes.forEach(dish => {
      text += `  ${i}. ${dish}\n`;
      i++;
    });
    text += '\n';
  });

  // Try to copy to clipboard
  if (navigator.clipboard) {
    navigator.clipboard.writeText(text).then(() => {
      alert('✅ 研究清单已复制到剪贴板！\n可以粘贴到微信、笔记等地方。');
    }).catch(() => {
      prompt('复制以下内容：', text);
    });
  } else {
    prompt('复制以下内容：', text);
  }
}

// Listen for storage changes from other tabs
window.addEventListener('storage', renderList);

// Render on load
renderList();
</script>

</body>
</html>
